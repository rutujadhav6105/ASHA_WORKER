# ============================================================
# ASHA Seva Backend — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — add it to .gitignore
# ============================================================

# ── Flask ────────────────────────────────────────────────────
FLASK_ENV=development
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string-in-production
PORT=5000

# ── PostgreSQL ───────────────────────────────────────────────
# Before starting: psql -U postgres -c "CREATE DATABASE asha_db;"
# Special characters in DB_PASSWORD (@ # % etc.) are URL-encoded automatically.
DB_NAME=asha_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# ── JWT ──────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=another-long-random-secret-for-jwt
# Token expiry in seconds: 3600 = 1 hour, 86400 = 24 hours
JWT_ACCESS_TOKEN_EXPIRES=3600

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Development: use * or specific emulator IPs
# Production: use your app's exact origin (e.g., https://yourdomain.com)
# Flutter Android emulator: http://10.0.2.2:5000
# Flutter iOS simulator:    http://localhost:5000
CORS_ORIGINS=http://localhost,http://10.0.2.2,http://127.0.0.1

# ── File Exports ─────────────────────────────────────────────
# Directory where CSV exports are saved (relative to backend/ root)
EXPORTS_DIR=exports

# ── Optional: Production overrides ───────────────────────────
# Uncomment and set for production deployments
# FLASK_ENV=production
# SQLALCHEMY_ECHO=false
# GUNICORN_WORKERS=4
# GUNICORN_BIND=0.0.0.0:5000
